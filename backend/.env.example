# ===== BACKEND ENVIRONMENT VARIABLES =====
# Copy these variables into Render's Environment Variables settings

# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=production

# ===== DATABASE =====
# MongoDB connection string with credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/techweb

# ===== JWT AUTHENTICATION =====
# Secret key for signing JWT tokens (generate a new secure key in production!)
# Use a strong, random 32+ character string
JWT_SECRET=your_long_secure_secret_key_minimum_32_characters_recommended
# Token expiration time (7d, 30d, 24h, etc.)
JWT_EXPIRES_IN=7d

# ===== CORS - Allowed Origins =====
# Comma-separated list of frontend URLs allowed to access this API
# Examples:
#   - Render: https://phoenixtechweb.onrender.com
#   - Vercel: https://your-domain.vercel.app
#   - Custom domain: https://phoenix-tech.in
CORS_ORIGIN=https://phoenixtechweb.onrender.com,https://your-vercel-domain.vercel.app,https://phoenix-tech.in

# ===== ADMIN SEEDING =====
# Used when running: npm run seed
# Initial admin credentials for first login (change in production!)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin@123

